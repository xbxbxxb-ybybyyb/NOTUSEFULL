module DolphinFrame::Login

def parse_info(host='old'){
    username = 'admin'
    password = '123456'
    old_cluster_id_list = ['168.17.250.47','168.17.250.48','168.17.250.49']
    new_cluster_id_list = ['168.17.249.171','168.17.249.172','168.17.249.173']
    if(host=='old'){cluster_ip = rand(old_cluster_id_list,1)[0]}
    else if(host=='new'){cluster_ip = rand(new_cluster_id_list,1)[0]}
    cluster_port = 8848
    cluster_ip = "168.61.13.40"
    return username, password, cluster_ip, cluster_port
}

def create_connection(host='old'){
    username, password, cluster_ip, cluster_port = parse_info(host)
    remote_conn=xdb(cluster_ip, cluster_port, username, password)
    return remote_conn
}

